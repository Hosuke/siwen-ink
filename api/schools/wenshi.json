"},{"dates":"c.1247-?","name":"張三丰","role":"武當祖師，內家拳源，集文始之成"}],"personas":["老子","尹喜","列子","文子","莊子","抱朴子"],"sub":"道家內丹頓派","sutra_registry_resolved":[]}